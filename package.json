{
  "name": "crypto-address-format",
  "version": "0.1.1",
  "description": "Universal format validation for crypto wallet addresses.",
  "keywords": [
    "address-validator",
    "bitcoin",
    "blockchain",
    "crypto",
    "ethereum",
    "wallet"
  ],
  "homepage": "https://github.com/fantasy42/crypto-address-format#readme",
  "bugs": {
    "url": "https://github.com/fantasy42/crypto-address-format/issues"
  },
  "license": "MIT",
  "author": "Fantasy <fntsy42@pm.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fantasy42/crypto-address-format.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      },
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.cts"
      }
    },
    "./bnb": {
      "import": {
        "default": "./dist/bnb.mjs",
        "types": "./dist/bnb.d.mts"
      },
      "require": {
        "default": "./dist/bnb.cjs",
        "types": "./dist/bnb.d.cts"
      }
    },
    "./btc": {
      "import": {
        "default": "./dist/btc.mjs",
        "types": "./dist/btc.d.mts"
      },
      "require": {
        "default": "./dist/btc.cjs",
        "types": "./dist/btc.d.cts"
      }
    },
    "./eth": {
      "import": {
        "default": "./dist/eth.mjs",
        "types": "./dist/eth.d.mts"
      },
      "require": {
        "default": "./dist/eth.cjs",
        "types": "./dist/eth.d.cts"
      }
    },
    "./polygon": {
      "import": {
        "default": "./dist/polygon.mjs",
        "types": "./dist/polygon.d.mts"
      },
      "require": {
        "default": "./dist/polygon.cjs",
        "types": "./dist/polygon.d.cts"
      }
    },
    "./trx": {
      "import": {
        "default": "./dist/trx.mjs",
        "types": "./dist/trx.d.mts"
      },
      "require": {
        "default": "./dist/trx.cjs",
        "types": "./dist/trx.d.cts"
      }
    },
    "./xrp": {
      "import": {
        "default": "./dist/xrp.mjs",
        "types": "./dist/xrp.d.mts"
      },
      "require": {
        "default": "./dist/xrp.cjs",
        "types": "./dist/xrp.d.cts"
      }
    },
    "./usdt-bep20": {
      "import": {
        "default": "./dist/usdt-bep20.mjs",
        "types": "./dist/usdt-bep20.d.mts"
      },
      "require": {
        "default": "./dist/usdt-bep20.cjs",
        "types": "./dist/usdt-bep20.d.cts"
      }
    },
    "./usdt-erc20": {
      "import": {
        "default": "./dist/usdt-erc20.mjs",
        "types": "./dist/usdt-erc20.d.mts"
      },
      "require": {
        "default": "./dist/usdt-erc20.cjs",
        "types": "./dist/usdt-erc20.d.cts"
      }
    },
    "./usdt-trc20": {
      "import": {
        "default": "./dist/usdt-trc20.mjs",
        "types": "./dist/usdt-trc20.d.mts"
      },
      "require": {
        "default": "./dist/usdt-trc20.cjs",
        "types": "./dist/usdt-trc20.d.cts"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/generateExports.ts",
    "build": "vp run prebuild && vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@noble/hashes": "2.2.0",
    "@types/node": "25.6.0",
    "bumpp": "11.0.1",
    "typescript": "6.0.2",
    "vite-plus": "0.1.18"
  },
  "peerDependencies": {
    "@noble/hashes": "^2.0.1"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
